APP_NAME=Peregrine
APP_VERSION=1.0.0-alpha.1
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# GitHub repository used by the update checker. Format: owner/repo.
UPDATE_REPO=Knaox/Peregrine

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Peregrine Installation
PANEL_INSTALLED=false

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=peregrine
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Drivers
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache
CACHE_STORE=redis
CACHE_PREFIX=peregrine_

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Authentication
AUTH_MODE=local
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_AUTHORIZE_URL=
OAUTH_TOKEN_URL=
OAUTH_USER_URL=

# Pelican
PELICAN_URL=
PELICAN_ADMIN_API_KEY=
PELICAN_CLIENT_API_KEY=

# Bridge (optional)
BRIDGE_ENABLED=false
STRIPE_WEBHOOK_SECRET=

# Docker (auto-detected)
DOCKER=false
DOCKER_APP_PORT=8080
DOCKER_DB_PORT=3306

# Mail (SMTP — required for invitations plugin)
MAIL_MAILER=smtp
MAIL_HOST=mail.rouge-informatique.ch
MAIL_PORT=587
MAIL_USERNAME=noreply@biomebounty.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@biomebounty.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
