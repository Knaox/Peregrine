{
  "id": "7-days-to-die",
  "version": "1.1.0",
  "name": {
    "en": "7 Days to Die",
    "fr": "7 Days to Die"
  },
  "description": {
    "en": "Complete server settings for 7 Days to Die — identity, network, slots, world generation, difficulty, zombies, blood moons, land claims, loot, plus the SandboxCode difficulty preset, with clear bilingual labels (serverconfig.xml).",
    "fr": "Paramètres serveur complets pour 7 Days to Die — identité, réseau, slots, génération du monde, difficulté, zombies, lunes de sang, claims, butin, plus le code Sandbox de difficulté, avec des libellés bilingues clairs (serverconfig.xml)."
  },
  "author": "Peregrine",
  "target_eggs": [],
  "columns": 2,
  "require_shutdown": false,
  "boost": {
    "enabled": true,
    "parameter_blacklist": [
      "ServerPort",
      "WebDashboardPort",
      "TelnetPort"
    ]
  },
  "files": [
    {
      "id": "serverconfig-xml",
      "path": "/serverconfig.xml",
      "format": "xml-property",
      "label": {
        "fr": "Paramètres du serveur",
        "en": "Server settings"
      },
      "expanded_by_default": true,
      "section_labels": {
        "ServerSettings": {
          "en": "Server Settings",
          "fr": "Paramètres du serveur"
        }
      },
      "parameters": {
        "ServerSettings": {
          "ServerName": {
            "display_type": "text",
            "config": {
              "default": "My Game Host",
              "max_length": 100
            },
            "label": {
              "en": "Server Name",
              "fr": "Nom du serveur"
            },
            "description": {
              "en": "Public name shown in the server browser.",
              "fr": "Nom public affiché dans le navigateur de serveurs."
            },
            "env_var": "SERVER_NAME"
          },
          "ServerDescription": {
            "display_type": "textarea",
            "config": {
              "default": "A 7 Days to Die server",
              "max_length": 500
            },
            "label": {
              "en": "Server Description",
              "fr": "Description du serveur"
            },
            "description": {
              "en": "Description shown alongside the server in the browser.",
              "fr": "Description affichée à côté du serveur dans le navigateur."
            }
          },
          "ServerWebsiteURL": {
            "display_type": "text",
            "config": {
              "default": null,
              "max_length": 255
            },
            "label": {
              "en": "Server Website URL",
              "fr": "URL du site du serveur"
            },
            "description": {
              "en": "Clickable website URL displayed in the server browser.",
              "fr": "URL cliquable affichée dans le navigateur de serveurs."
            }
          },
          "ServerPassword": {
            "display_type": "text",
            "config": {
              "default": null,
              "max_length": 100
            },
            "label": {
              "en": "Server Password",
              "fr": "Mot de passe du serveur"
            },
            "description": {
              "en": "Password required to join the server. Leave empty for no password.",
              "fr": "Mot de passe requis pour rejoindre le serveur. Laisser vide pour aucun mot de passe."
            },
            "env_var": "PASSWORD"
          },
          "ServerLoginConfirmationText": {
            "display_type": "textarea",
            "config": {
              "default": null,
              "max_length": 1000
            },
            "label": {
              "en": "Login Confirmation Text",
              "fr": "Texte de confirmation de connexion"
            },
            "description": {
              "en": "Message shown to players when joining; they must accept it to continue.",
              "fr": "Message affiché aux joueurs lors de la connexion ; ils doivent l'accepter pour continuer."
            }
          },
          "Region": {
            "display_type": "select",
            "config": {
              "default": "NorthAmericaEast",
              "options": [
                {
                  "value": "NorthAmericaEast",
                  "label": {
                    "en": "North America East",
                    "fr": "Amérique du Nord Est"
                  }
                },
                {
                  "value": "NorthAmericaWest",
                  "label": {
                    "en": "North America West",
                    "fr": "Amérique du Nord Ouest"
                  }
                },
                {
                  "value": "CentralAmerica",
                  "label": {
                    "en": "Central America",
                    "fr": "Amérique centrale"
                  }
                },
                {
                  "value": "SouthAmerica",
                  "label": {
                    "en": "South America",
                    "fr": "Amérique du Sud"
                  }
                },
                {
                  "value": "Europe",
                  "label": {
                    "en": "Europe",
                    "fr": "Europe"
                  }
                },
                {
                  "value": "Russia",
                  "label": {
                    "en": "Russia",
                    "fr": "Russie"
                  }
                },
                {
                  "value": "Asia",
                  "label": {
                    "en": "Asia",
                    "fr": "Asie"
                  }
                },
                {
                  "value": "MiddleEast",
                  "label": {
                    "en": "Middle East",
                    "fr": "Moyen-Orient"
                  }
                },
                {
                  "value": "Africa",
                  "label": {
                    "en": "Africa",
                    "fr": "Afrique"
                  }
                },
                {
                  "value": "Oceania",
                  "label": {
                    "en": "Oceania",
                    "fr": "Océanie"
                  }
                }
              ]
            },
            "label": {
              "en": "Region",
              "fr": "Région"
            },
            "description": {
              "en": "Geographic region of the server, used for matchmaking.",
              "fr": "Région géographique du serveur, utilisée pour le matchmaking."
            }
          },
          "Language": {
            "display_type": "text",
            "config": {
              "default": "English",
              "max_length": 50
            },
            "label": {
              "en": "Language",
              "fr": "Langue"
            },
            "description": {
              "en": "Primary language displayed to players searching for the server.",
              "fr": "Langue principale affichée aux joueurs cherchant le serveur."
            }
          },
          "ServerPort": {
            "display_type": "number",
            "config": {
              "min": 1024,
              "max": 65535,
              "step": 1,
              "default": 26900
            },
            "label": {
              "en": "Server Port",
              "fr": "Port du serveur"
            },
            "description": {
              "en": "Network port the server listens on. Keep within 26900–26905 or 27015–27020 for LAN discovery.",
              "fr": "Port réseau d'écoute du serveur. Restez entre 26900–26905 ou 27015–27020 pour la découverte LAN."
            }
          },
          "ServerVisibility": {
            "display_type": "select",
            "config": {
              "default": 2,
              "options": [
                {
                  "value": 0,
                  "label": {
                    "en": "Not listed",
                    "fr": "Non listé"
                  }
                },
                {
                  "value": 1,
                  "label": {
                    "en": "Friends only",
                    "fr": "Amis uniquement"
                  }
                },
                {
                  "value": 2,
                  "label": {
                    "en": "Public",
                    "fr": "Public"
                  }
                }
              ]
            },
            "label": {
              "en": "Server Visibility",
              "fr": "Visibilité du serveur"
            },
            "description": {
              "en": "Who can see the server in the public browser.",
              "fr": "Qui peut voir le serveur dans le navigateur public."
            }
          },
          "ServerDisabledNetworkProtocols": {
            "display_type": "multiselect",
            "config": {
              "default": "SteamNetworking",
              "separator": ",",
              "options": [
                {
                  "value": "SteamNetworking",
                  "label": {
                    "en": "Steam Networking",
                    "fr": "Réseau Steam"
                  }
                },
                {
                  "value": "LiteNetLib",
                  "label": {
                    "en": "LiteNetLib",
                    "fr": "LiteNetLib"
                  }
                }
              ]
            },
            "label": {
              "en": "Disabled Network Protocols",
              "fr": "Protocoles réseau désactivés"
            },
            "description": {
              "en": "Networking protocols that should NOT be used. Disable SteamNetworking on dedicated servers with proper port-forwarding.",
              "fr": "Protocoles réseau qui ne doivent PAS être utilisés. Désactivez SteamNetworking sur les serveurs dédiés avec une bonne redirection de ports."
            },
            "env_var": "SERVER_DISABLED_NETWORK_PROTOCOLS"
          },
          "ServerMaxWorldTransferSpeedKiBs": {
            "display_type": "slider",
            "config": {
              "min": 64,
              "max": 1300,
              "step": 64,
              "default": 512
            },
            "label": {
              "en": "World Transfer Speed (KiB/s)",
              "fr": "Vitesse de transfert du monde (Kio/s)"
            },
            "description": {
              "en": "Maximum world transfer speed when a client connects for the first time. Hard cap is ~1300 KiB/s.",
              "fr": "Vitesse maximale de transfert du monde lors de la première connexion d'un client. Plafond ~1300 Kio/s."
            }
          },
          "ServerMaxPlayerCount": {
            "display_type": "slider",
            "config": {
              "min": 1,
              "max": 64,
              "step": 1,
              "default": 8
            },
            "label": {
              "en": "Max Players",
              "fr": "Joueurs max"
            },
            "description": {
              "en": "Maximum concurrent players allowed on the server.",
              "fr": "Nombre maximal de joueurs simultanés autorisés sur le serveur."
            },
            "env_var": "MAX_PLAYERS"
          },
          "ServerReservedSlots": {
            "display_type": "slider",
            "config": {
              "min": 0,
              "max": 64,
              "step": 1,
              "default": 0
            },
            "label": {
              "en": "Reserved Slots",
              "fr": "Slots réservés"
            },
            "description": {
              "en": "Slots usable only by players above a specific permission level.",
              "fr": "Slots utilisables uniquement par les joueurs au-dessus d'un niveau de permission donné."
            }
          },
          "ServerReservedSlotsPermission": {
            "display_type": "slider",
            "config": {
              "min": 0,
              "max": 1000,
              "step": 1,
              "default": 100
            },
            "label": {
              "en": "Reserved Slots Permission Level",
              "fr": "Niveau de permission slots réservés"
            },
            "description": {
              "en": "Required permission level to use reserved slots.",
              "fr": "Niveau de permission requis pour utiliser les slots réservés."
            }
          },
          "ServerAdminSlots": {
            "display_type": "slider",
            "config": {
              "min": 0,
              "max": 16,
              "step": 1,
              "default": 0
            },
            "label": {
              "en": "Admin Slots",
              "fr": "Slots admin"
            },
            "description": {
              "en": "Extra slots reserved for admins even when MaxPlayerCount is reached.",
              "fr": "Slots supplémentaires réservés aux admins même quand MaxPlayerCount est atteint."
            }
          },
          "ServerAdminSlotsPermission": {
            "display_type": "slider",
            "config": {
              "min": 0,
              "max": 1000,
              "step": 1,
              "default": 0
            },
            "label": {
              "en": "Admin Slots Permission Level",
              "fr": "Niveau de permission slots admin"
            },
            "description": {
              "en": "Required permission level to use admin slots.",
              "fr": "Niveau de permission requis pour utiliser les slots admin."
            }
          },
          "WebDashboardEnabled": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "false"
            },
            "label": {
              "en": "Enable Web Dashboard",
              "fr": "Activer le tableau de bord web"
            },
            "description": {
              "en": "Enables the built-in web administration dashboard.",
              "fr": "Active le tableau de bord d'administration web intégré."
            }
          },
          "WebDashboardPort": {
            "display_type": "number",
            "config": {
              "min": 1024,
              "max": 65535,
              "step": 1,
              "default": 8080
            },
            "label": {
              "en": "Web Dashboard Port",
              "fr": "Port du tableau de bord web"
            },
            "description": {
              "en": "Network port used by the web dashboard.",
              "fr": "Port réseau utilisé par le tableau de bord web."
            }
          },
          "WebDashboardUrl": {
            "display_type": "text",
            "config": {
              "default": null,
              "max_length": 255
            },
            "label": {
              "en": "Web Dashboard External URL",
              "fr": "URL externe du tableau de bord"
            },
            "description": {
              "en": "External URL of the dashboard, e.g. behind a reverse proxy.",
              "fr": "URL externe du tableau de bord, par exemple derrière un reverse proxy."
            }
          },
          "EnableMapRendering": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "false"
            },
            "label": {
              "en": "Enable Map Rendering",
              "fr": "Activer le rendu de la carte"
            },
            "description": {
              "en": "Renders the map to tile images as players explore (used by the web dashboard).",
              "fr": "Génère le rendu de la carte en tuiles au fil de l'exploration (utilisé par le tableau de bord web)."
            }
          },
          "TelnetEnabled": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "true"
            },
            "label": {
              "en": "Enable Telnet",
              "fr": "Activer Telnet"
            },
            "description": {
              "en": "Enables the Telnet administration interface.",
              "fr": "Active l'interface d'administration Telnet."
            }
          },
          "TelnetPort": {
            "display_type": "number",
            "config": {
              "min": 1024,
              "max": 65535,
              "step": 1,
              "default": 8081
            },
            "label": {
              "en": "Telnet Port",
              "fr": "Port Telnet"
            },
            "description": {
              "en": "Network port used by the Telnet server.",
              "fr": "Port réseau utilisé par le serveur Telnet."
            },
            "env_var": "TELNET_PORT"
          },
          "TelnetPassword": {
            "display_type": "text",
            "config": {
              "default": null,
              "max_length": 100
            },
            "label": {
              "en": "Telnet Password",
              "fr": "Mot de passe Telnet"
            },
            "description": {
              "en": "Password for Telnet access. If empty, Telnet listens only on localhost.",
              "fr": "Mot de passe pour l'accès Telnet. Si vide, Telnet n'écoute que sur localhost."
            }
          },
          "TelnetFailedLoginLimit": {
            "display_type": "slider",
            "config": {
              "min": 1,
              "max": 50,
              "step": 1,
              "default": 10
            },
            "label": {
              "en": "Telnet Failed Login Limit",
              "fr": "Limite d'échecs de connexion Telnet"
            },
            "description": {
              "en": "Number of failed password attempts before a client is blocked.",
              "fr": "Nombre de tentatives de mot de passe échouées avant blocage du client."
            }
          },
          "TelnetFailedLoginsBlocktime": {
            "display_type": "slider",
            "config": {
              "min": 1,
              "max": 3600,
              "step": 1,
              "default": 10
            },
            "label": {
              "en": "Telnet Block Duration (s)",
              "fr": "Durée de blocage Telnet (s)"
            },
            "description": {
              "en": "How long, in seconds, a blocked client remains banned from Telnet.",
              "fr": "Durée, en secondes, pendant laquelle un client bloqué reste banni de Telnet."
            }
          },
          "TerminalWindowEnabled": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "true"
            },
            "label": {
              "en": "Show Terminal Window",
              "fr": "Afficher la fenêtre terminal"
            },
            "description": {
              "en": "Shows a terminal window for log output and input on Windows.",
              "fr": "Affiche une fenêtre terminal pour les logs et la saisie sur Windows."
            }
          },
          "AdminFileName": {
            "display_type": "text",
            "config": {
              "default": "serveradmin.xml",
              "max_length": 100
            },
            "label": {
              "en": "Admin File Name",
              "fr": "Nom du fichier admin"
            },
            "description": {
              "en": "Name of the server admin file, relative to UserDataFolder/Saves.",
              "fr": "Nom du fichier admin du serveur, relatif à UserDataFolder/Saves."
            }
          },
          "ServerAllowCrossplay": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "false"
            },
            "label": {
              "en": "Allow Crossplay",
              "fr": "Autoriser le crossplay"
            },
            "description": {
              "en": "Allows crossplay between platforms. Requires sanctions enabled and default slot count.",
              "fr": "Autorise le crossplay entre plateformes. Nécessite les sanctions activées et un nombre de slots par défaut."
            }
          },
          "EACEnabled": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "true"
            },
            "label": {
              "en": "EasyAntiCheat Enabled",
              "fr": "EasyAntiCheat activé"
            },
            "description": {
              "en": "Enables EasyAntiCheat protection.",
              "fr": "Active la protection EasyAntiCheat."
            }
          },
          "IgnoreEOSSanctions": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "false"
            },
            "label": {
              "en": "Ignore EOS Sanctions",
              "fr": "Ignorer les sanctions EOS"
            },
            "description": {
              "en": "Ignore EOS sanctions when allowing players to join.",
              "fr": "Ignore les sanctions EOS lors de l'acceptation des joueurs."
            }
          },
          "HideCommandExecutionLog": {
            "display_type": "select",
            "config": {
              "default": 0,
              "options": [
                {
                  "value": 0,
                  "label": {
                    "en": "Show everything",
                    "fr": "Tout afficher"
                  }
                },
                {
                  "value": 1,
                  "label": {
                    "en": "Hide from Telnet/Control Panel",
                    "fr": "Masquer de Telnet/Panneau de contrôle"
                  }
                },
                {
                  "value": 2,
                  "label": {
                    "en": "Also hide from remote clients",
                    "fr": "Masquer aussi des clients distants"
                  }
                },
                {
                  "value": 3,
                  "label": {
                    "en": "Hide everything",
                    "fr": "Tout masquer"
                  }
                }
              ]
            },
            "label": {
              "en": "Hide Command Execution Log",
              "fr": "Masquer les logs d'exécution de commandes"
            },
            "description": {
              "en": "Controls where command execution is logged.",
              "fr": "Contrôle où les exécutions de commandes sont enregistrées."
            }
          },
          "MaxUncoveredMapChunksPerPlayer": {
            "display_type": "number",
            "config": {
              "min": 1024,
              "max": 1048576,
              "step": 1024,
              "default": 131072
            },
            "label": {
              "en": "Max Uncovered Map Chunks / Player",
              "fr": "Chunks de carte découverts max / joueur"
            },
            "description": {
              "en": "Maximum chunks each player can uncover on the in-game map.",
              "fr": "Nombre maximal de chunks que chaque joueur peut découvrir sur la carte."
            }
          },
          "PersistentPlayerProfiles": {
            "display_type": "boolean",
            "config": {
              "true_value": "true",
              "false_value": "false",
              "default": "false"
            },
            "label": {
              "en": "Persistent Player Profiles",
              "fr": "Profils de joueurs persistants"
            },
            "description": {
              "en": "If true, players always rejoin with the last profile they used.",
              "fr": "Si activé, les joueurs reviennent toujours avec le dernier profil utilisé."
            }
          },
          "MaxChunkAge": {
            "display_type": "number",
            "config": {
              "min": -1,
              "max": 365,
              "step": 1,
              "default": -1
            },
            "label": {
              "en": "Max Chunk Age (days)",
              "fr": "Âge max d'un chunk (jours)"
            },
            "description": {
              "en": "In-game days before an unvisited chunk resets to its original state. -1 disables reset.",
              "fr": "Jours en jeu avant qu'un chunk non visité ne se réinitialise. -1 désactive la réinitialisation."
            }
          },
          "SaveDataLimit": {
            "display_type": "number",
            "config": {
              "min": -1,
              "max": 1048576,
              "step": 1,
              "default": -1
            },
            "label": {
              "en": "Save Data Limit (MB)",
              "fr": "Limite des données sauvegardées (Mo)"
            },
            "description": {
              "en": "Maximum disk space per save in MB. Negative values disable the limit.",
              "fr": "Espace disque maximum par sauvegarde en Mo. Une valeur négative désactive la limite."
            }
          },
          "GameWorld": {
            "display_type": "select",
            "config": {
              "default": "Navezgane",
              "options": [
                {
                  "value": "Navezgane",
                  "label": {
                    "en": "Navezgane",
                    "fr": "Navezgane"
                  }
                },
                {
                  "value": "RWG",
                  "label": {
                    "en": "Random World Gen",
                    "fr": "Génération aléatoire"
                  }
                },
                {
                  "value": "Pregen06k01",
                  "label": {
                    "en": "Pregen 6K #1",
                    "fr": "Pré-généré 6K n°1"
                  }
                },
                {
                  "value": "Pregen06k02",
                  "label": {
                    "en": "Pregen 6K #2",
                    "fr": "Pré-généré 6K n°2"
                  }
                },
                {
                  "value": "Pregen08k01",
                  "label": {
                    "en": "Pregen 8K #1",
                    "fr": "Pré-généré 8K n°1"
                  }
                },
                {
                  "value": "Pregen08k02",
                  "label": {
                    "en": "Pregen 8K #2",
                    "fr": "Pré-généré 8K n°2"
                  }
                }
              ]
            },
            "label": {
              "en": "Game World",
              "fr": "Monde de jeu"
            },
            "description": {
              "en": "World loaded by the server. Use RWG to generate a random world.",
              "fr": "Monde chargé par le serveur. Utilisez RWG pour générer un monde aléatoire."
            }
          },
          "WorldGenSeed": {
            "display_type": "text",
            "config": {
              "default": "MyGame",
              "max_length": 100
            },
            "label": {
              "en": "World Gen Seed",
              "fr": "Seed de génération"
            },
            "description": {
              "en": "Seed used to generate the world when GameWorld is set to RWG.",
              "fr": "Seed utilisée pour générer le monde quand GameWorld vaut RWG."
            }
          },
          "WorldGenSize": {
            "display_type": "select",
            "config": {
              "default": 6144,
              "options": [
                {
                  "value": 6144,
                  "label": {
                    "en": "6144 (6K)",
                    "fr": "6144 (6K)"
                  }
                },
                {
                  "value": 8192,
                  "label": {
                    "en": "8192 (8K)",
                    "fr": "8192 (8K)"
                  }
                },
                {
                  "value": 10240,
                  "label": {
                    "en": "10240 (10K)",
                    "fr": "10240 (10K)"
                  }
                }
              ]
            },
            "label": {
              "en": "World Gen Size",
              "fr": "Taille du monde généré"
            },
            "description": {
              "en": "Size (in blocks) of an RWG world.",
              "fr": "Taille (en blocs) d'un monde RWG."
            }
          },
          "GameName": {
            "display_type": "text",
            "config": {
              "default": "MyGame",
              "max_length": 100,
              "regex": "^[A-Za-z0-9_\\-. ]+$"
            },
            "label": {
