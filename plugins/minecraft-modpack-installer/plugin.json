{
    "id": "minecraft-modpack-installer",
    "name": "Minecraft: Modpack - Installer",
    "version": "1.0.0",
    "description": "Install, update and remove Minecraft modpacks on a server in a few clicks. Aggregates Modrinth, CurseForge, ATLauncher, Feed The Beast, Technic and VoidsWrath. Auto-detects the required Java version after install and switches the server runtime accordingly.",
    "author": "Peregrine",
    "vendor": "peregrine",
    "license": "MIT",
    "min_peregrine_version": "1.0.0",
    "bundled": true,
    "service_provider": "MinecraftModpackInstallerServiceProvider",
    "manage_url": "/admin/modpack-configs",
    "frontend": {
        "bundle": "frontend/dist/bundle.js",
        "nav": [],
        "server_sidebar_entries": [
            {
                "id": "modpacks",
                "label_key": "minecraft-modpack-installer:modpacks.tab.label",
                "icon": "package",
                "route_suffix": "/modpacks",
                "order": 9,
                "required_permission": "modpack.read"
            }
        ]
    },
    "settings_schema": []
}
