# Installed plugins — only the official bundled plugin `invitations` is
# part of the upstream repo. Locally installed plugins from the marketplace
# live in plugins/ but must not be committed. egg-config-editor and
# minecraft-modpack-installer were removed from the bundle on 2026-05-08;
# both ship through the marketplace and are downloaded on demand.
/plugins/*
!/plugins/autoload.php
!/plugins/invitations/
!/plugins/invitations/**
# The built bundle IS committed (so fresh clones can activate the plugin
# without a pnpm build), but node_modules stays ignored.
/plugins/invitations/frontend/node_modules

# Easy Configuration — first-party plugin shipped through this repo so it can
# be forked from GitHub (its templates are meant to be shared). Mirrors the
# invitations exception above: sources + built bundle tracked, deps ignored.
!/plugins/easy-configuration/
!/plugins/easy-configuration/**
/plugins/easy-configuration/frontend/node_modules
/plugins/easy-configuration/tests/.phpunit.cache

# phpMyAdmin Integration — first-party plugin shipped through this repo.
# Mirrors the exceptions above: sources + built bundle tracked, deps + test
# cache ignored.
!/plugins/peregrine-phpmyadmin/
!/plugins/peregrine-phpmyadmin/**
/plugins/peregrine-phpmyadmin/frontend/node_modules
/plugins/peregrine-phpmyadmin/tests/.phpunit.cache

# Player Counter — first-party plugin shipped through this repo. Mirrors the
# exceptions above: sources + built bundle tracked, deps ignored. The sidecar's
# node_modules (the gamedig runtime) are installed at deploy time, not committed.
!/plugins/peregrine-player-counter/
!/plugins/peregrine-player-counter/**
/plugins/peregrine-player-counter/sidecar/node_modules
/plugins/peregrine-player-counter/frontend/node_modules

# Plugin asset symlinks — created at activation time by PluginManager,
# never committed (point to absolute host paths).
/public/plugins/

# Release artifacts zipped at the repo root during marketplace publish steps.
/*.zip

# Claude Code workspace files (kept local only — never committed)
CLAUDE.md
.claude/

# One-off migration / refactor scripts. Kept locally as a reference for the
# next time we need to do the same kind of operation (e.g. another i18n
# split), but never shipped to GitHub — they're already-applied tooling, not
# part of the runtime panel.
/scripts/

# Internal feature spec drafts — kept locally as working notes, never
# shipped (the user-facing docs live under resources/views/docs/).
MODPACK_FEATURE_SPEC.md
