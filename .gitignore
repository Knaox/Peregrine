# Installed plugins — only the official bundled plugin `invitations` is
# part of the upstream repo. Locally installed plugins from the marketplace
# live in plugins/ but must not be committed. egg-config-editor and
# minecraft-modpack-installer were removed from the bundle on 2026-05-08;
# both ship through the marketplace and are downloaded on demand.
/plugins/*
!/plugins/autoload.php
!/plugins/invitations/
!/plugins/invitations/**
# The built bundle IS committed (so fresh clones can activate the plugin
# without a pnpm build), but node_modules stays ignored.
/plugins/invitations/frontend/node_modules

# Plugin asset symlinks — created at activation time by PluginManager,
# never committed (point to absolute host paths).
/public/plugins/

# Release artifacts zipped at the repo root during marketplace publish steps.
/*.zip

# Claude Code workspace files (kept local only — never committed)
CLAUDE.md
.claude/
