# Installed plugins — only the official bundled plugins (invitations,
# egg-config-editor) are part of the upstream repo. Locally installed
# plugins from the marketplace live in plugins/ but must not be committed.
/plugins/*
!/plugins/autoload.php
!/plugins/invitations/
!/plugins/invitations/**
!/plugins/egg-config-editor/
!/plugins/egg-config-editor/**
# The built bundles ARE committed (so fresh clones can activate plugins
# without a pnpm build), but node_modules stays ignored.
/plugins/invitations/frontend/node_modules
/plugins/egg-config-editor/frontend/node_modules

# Plugin asset symlinks — created at activation time by PluginManager,
# never committed (point to absolute host paths).
/public/plugins/

# Release artifacts zipped at the repo root during marketplace publish steps.
/*.zip
