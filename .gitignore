# Installed plugins — only the official bundled plugins (invitations,
# minecraft-modpack-installer) are part of the upstream repo. Locally
# installed plugins from the marketplace live in plugins/ but must not
# be committed. egg-config-editor was removed from the bundle on
# 2026-05-08 — it'll come back through the marketplace when ready.
/plugins/*
!/plugins/autoload.php
!/plugins/invitations/
!/plugins/invitations/**
!/plugins/minecraft-modpack-installer/
!/plugins/minecraft-modpack-installer/**
# The built bundles ARE committed (so fresh clones can activate plugins
# without a pnpm build), but node_modules stays ignored.
/plugins/invitations/frontend/node_modules
/plugins/minecraft-modpack-installer/frontend/node_modules

# Plugin asset symlinks — created at activation time by PluginManager,
# never committed (point to absolute host paths).
/public/plugins/

# Release artifacts zipped at the repo root during marketplace publish steps.
/*.zip

# Claude Code workspace files (kept local only — never committed)
CLAUDE.md
.claude/
