{
    "name": "peregrine/peregrine-shop-sdk",
    "description": "PHP SDK for integrating a third-party shop with Peregrine's public API + Standard Webhooks.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Peregrine\\ShopSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Peregrine\\ShopSdk\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
